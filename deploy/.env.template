# Production .env template, rendered by envsubst in the GitHub Actions
# deploy job. Each placeholder below is sourced from a GitHub repository
# secret. After substitution, the result is uploaded to /opt/anynote/.env
# on the server and consumed by `docker compose up -d`.

# === Public URLs ===
NEXT_PUBLIC_BASE_URL=${NEXT_PUBLIC_BASE_URL}
YANDEX_VERIFICATION=${YANDEX_VERIFICATION}
GOOGLE_SITE_VERIFICATION=${GOOGLE_SITE_VERIFICATION}
SEO_NOINDEX_ALL=${SEO_NOINDEX_ALL}
BETTER_AUTH_URL=${BETTER_AUTH_URL}
BETTER_AUTH_SECRET=${BETTER_AUTH_SECRET}
BETTER_AUTH_JWT_AUDIENCE=${BETTER_AUTH_JWT_AUDIENCE}
NEXT_PUBLIC_YJS_URL=${NEXT_PUBLIC_YJS_URL}
YJS_PORT=1234

# === Database (Prisma â€” web/engines/yjs) ===
DATABASE_URL=${DATABASE_URL}
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}

# === Database (agents â€” fast_clean nested settings) ===
DB__PROVIDER=postgresql
DB__HOST=postgres
DB__PORT=5432
DB__USER=anynote
DB__PASSWORD=${DB__PASSWORD}
DB__NAME=agents

# === S3 / MinIO ===
S3_ENDPOINT=${S3_ENDPOINT}
S3_REGION=${S3_REGION}
S3_ACCESS_KEY=${S3_ACCESS_KEY}
S3_SECRET_KEY=${S3_SECRET_KEY}
S3_BUCKET=${S3_BUCKET}
S3_FORCE_PATH_STYLE=${S3_FORCE_PATH_STYLE}

# === Qdrant ===
QDRANT__HOST=${QDRANT__HOST}
QDRANT__AUTH__TYPE=${QDRANT__AUTH__TYPE}
QDRANT__AUTH__BEARER_TOKEN=${QDRANT__AUTH__BEARER_TOKEN}
QDRANT__COLLECTION_NAME=${QDRANT__COLLECTION_NAME}

# === Inter-service ===
AGENTS_SERVICE_URL=${AGENTS_SERVICE_URL}
AGENTS_SERVICE_TOKEN=${AGENTS_SERVICE_TOKEN}
ENGINES_SERVICE_URL=${ENGINES_URL}:${ENGINES_PORT}
ENGINES_MCP_URL=${ENGINES_URL}:${ENGINES_PORT}/mcp
ENGINES_MCP_TOKEN=${ENGINES_MCP_TOKEN}
ANYNOTE_MCP_URL=${ENGINES_URL}:${ENGINES_PORT}/mcp
ENGINES_PORT=${ENGINES_PORT}

# === Agent OS (v1.19.0+) ===
# Internal docker-network URLs. Both web and agents containers resolve each
# other by service name via the default `anynote` compose network.
AGENTS_URL=http://agents:8080
WEB_BASE_URL=http://web:3000
# HMAC HS256 secret signing the short-lived JWT apps/web â†’ apps/agents
# attaches as Bearer token (and the callbacks agents sends to web). 32
# random bytes, base64. Must be identical on both sides.
AGENTS_JWT_SECRET=${AGENTS_JWT_SECRET}
BETTER_AUTH_JWT_AGENTS_AUDIENCE=agents
# HMAC secret shared between apps/agents and the apps/engines MCP guard.
AGENTS_TO_ENGINES_SECRET=${AGENTS_TO_ENGINES_SECRET}
# AES-256-GCM master key encrypting workspace AI/MCP secrets at rest.
SECRETS_ENCRYPTION_KEY=${SECRETS_ENCRYPTION_KEY}
# Used by the engines cleanup worker to prune LangGraph checkpointer state
# from the agents Postgres database.
AGENTS_DATABASE_URL=postgresql://anynote:${DB__PASSWORD}@postgres:5432/agents

# === Agents service settings (fast_clean) ===
ENVIRONMENT=prod
DEBUG=false
TITLE=AI Agents
SECRET_KEY=${AGENTS_SECRET_KEY}
BASE_URL=${NEXT_PUBLIC_BASE_URL}
CORS_ORIGINS=["https://anynote.ru","https://www.anynote.ru"]
AGENTS_LOG_LEVEL=INFO

# === Mail (SendSay) ===
SENDSAY_API_URL=${SENDSAY_API_URL}
SENDSAY_API_KEY=${SENDSAY_API_KEY}

# === Indexer cron ===
INDEXER_CRON_EXPRESSION=0 */5 * * * *
INDEXER_MAX_ATTEMPTS=5
INDEXER_BATCH=10
UPLOAD_INLINE_MAX_BYTES=1048576

# === OAuth providers ===
GOOGLE_CLIENT_ID=${GOOGLE_CLIENT_ID}
GOOGLE_CLIENT_SECRET=${GOOGLE_CLIENT_SECRET}

# === reCAPTCHA v3 ===
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=${NEXT_PUBLIC_RECAPTCHA_SITE_KEY}
RECAPTCHA_SECRET_KEY=${RECAPTCHA_SECRET_KEY}

# === Server-side export (PDF) ===
# Gotenberg runs as a sidecar in compose; reached on the internal network.
GOTENBERG_URL=${GOTENBERG_URL}
GOTENBERG_TIMEOUT_MS=${GOTENBERG_TIMEOUT_MS}
# PlantUML server runs as a sidecar in compose; reached on the internal network.
PLANTUML_URL=${PLANTUML_URL}
PLANTUML_TIMEOUT_MS=${PLANTUML_TIMEOUT_MS}

# === Billing (YooKassa) ===
YOOKASSA_SHOP_ID=${YOOKASSA_SHOP_ID}
YOOKASSA_SECRET_KEY=${YOOKASSA_SECRET_KEY}
YOOKASSA_RETURN_URL_BASE=${NEXT_PUBLIC_BASE_URL}
YOOKASSA_SAVE_PAYMENT_METHOD=${YOOKASSA_SAVE_PAYMENT_METHOD}
BILLING_RENEWAL_CRON_EXPRESSION=0 0 0 * * *
BILLING_RENEWAL_BATCH_SIZE=50

# === Web Push (VAPID) ===
# NEXT_PUBLIC_VAPID_PUBLIC_KEY is ALSO passed as a docker build-arg to
# apps/web in deploy.yml so Next.js inlines the real key into the client
# bundle â€” the value here is only used by the engines notifier worker.
VAPID_PUBLIC_KEY=${VAPID_PUBLIC_KEY}
NEXT_PUBLIC_VAPID_PUBLIC_KEY=${NEXT_PUBLIC_VAPID_PUBLIC_KEY}
VAPID_PRIVATE_KEY=${VAPID_PRIVATE_KEY}
VAPID_SUBJECT=${VAPID_SUBJECT}

# === Traefik ACME email (compose interpolation only â€” not passed to app containers) ===
# TRAEFIK_DASHBOARD_USERS_LINE intentionally not here: bcrypt hashes contain
# $-chars that compose tries to interpret as variable references. The deploy
# job writes that secret directly to deploy/traefik/dynamic/dashboard-users
# on the server.
ACME_EMAIL=${ACME_EMAIL}
