{
  "name": "engines",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node --env-file=../../.env dist/main.js",
    "check-types": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test-int": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.integration.config.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^4.1.0",
    "@nestjs/swagger": "^11.0.0",
    "@rekog/mcp-nest": "^1.5.0",
    "@repo/db": "workspace:*",
    "@repo/storage": "workspace:*",
    "cron": "^3.2.0",
    "dotenv": "^17.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
