{
  "name": "engines",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "uv run uvicorn --factory engines.main:create_app --host 0.0.0.0 --port 8082 --reload",
    "build": "uv sync --frozen",
    "check-types": "uv run mypy engines tests",
    "lint": "uv run ruff check engines tests",
    "format": "uv run ruff format engines tests",
    "test": "uv run pytest -m 'not integration'"
  }
}
