{
  "name": "desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main/index.cjs",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch & electron .",
    "lint": "eslint --max-warnings 0 src",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "dist": "pnpm build && electron-builder && pnpm copy-to-web",
    "dist:mac": "pnpm build && electron-builder --mac && pnpm copy-to-web",
    "dist:win": "pnpm build && electron-builder --win && pnpm copy-to-web",
    "dist:linux": "pnpm build && electron-builder --linux && pnpm copy-to-web",
    "copy-to-web": "node scripts/copy-to-web.mjs"
  },
  "dependencies": {
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.19.1",
    "electron": "^37.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0",
    "eslint": "^9.39.1",
    "typescript": "^5.9.2",
    "vitest": "^3.0.0"
  }
}
