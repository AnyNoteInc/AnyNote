# AnyNote local-dev environment variables. Copy to `.env` and fill in.

# ── Web (apps/web) ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/anynote
NEXT_PUBLIC_BASE_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=change-me-32-chars-min
BETTER_AUTH_JWT_AUDIENCE=anynote-yjs

# ── S3 / MinIO (file storage) ───────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=admin
S3_SECRET_KEY=password
S3_BUCKET=storage
S3_FORCE_PATH_STYLE=true

# ── Realtime collaboration (apps/yjs) ───────────────────────────────
NEXT_PUBLIC_YJS_URL=ws://localhost:1234
YJS_PORT=1234

# ── Agents service (apps/agents, Pillar B1) ─────────────────────────
AGENTS_DATABASE_URL=postgresql://user:password@localhost:5432/agents
AGENTS_SERVICE_URL=http://localhost:8080
AGENTS_SERVICE_TOKEN=test-token-123
AGENTS_LOG_LEVEL=INFO

# ── Qdrant (vector DB, shared) ──────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=dev-qdrant-key
QDRANT_COLLECTION=anynote-pages

# ── Ollama (local LLM + embeddings) ─────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen2.5:0.5b

# ── Indexer (apps/indexer, Pillar D) ────────────────────────────────
INDEXER_DATABASE_URL=postgresql://user:password@localhost:5432/anynote
INDEXER_QDRANT_URL=http://localhost:6333
INDEXER_QDRANT_API_KEY=dev-qdrant-key
INDEXER_QDRANT_COLLECTION=anynote-pages
INDEXER_POLL_INTERVAL_MS=1000
INDEXER_BATCH=16
INDEXER_LOCK_TTL_MS=60000
INDEXER_MAX_ATTEMPTS=5
INDEXER_LOG_LEVEL=INFO

# Embeddings (consumed by indexer + future apps/engines)
EMBEDDINGS_PROVIDER=ollama
EMBEDDINGS_MODEL=nomic-embed-text
EMBEDDINGS_DIM=768

OPENAI_API_KEY=

# ── Engines (apps/engines, Pillar E — placeholder) ──────────────────
ENGINES_PORT=8082
ENGINES_MCP_TOKEN=test-engines-token
