# AnyNote local-dev environment variables. Copy to `.env` and fill in.

# ── Web (apps/web) ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/anynote
NEXT_PUBLIC_BASE_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
WEB_BASE_URL=http://localhost:3000
BETTER_AUTH_SECRET=change-me-32-chars-min
BETTER_AUTH_JWT_AUDIENCE=anynote-yjs

# Audience claim used when minting short-lived JWTs that apps/web sends to
# apps/agents (and that agents sends back for callbacks). 5-minute TTL.
BETTER_AUTH_JWT_AGENTS_AUDIENCE=agents

# HMAC shared secret signing agents JWTs (HS256). 32 random bytes, base64.
# Lives in both apps/web and apps/agents. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AGENTS_JWT_SECRET=

# HMAC shared secret between apps/agents and apps/engines MCP. 32 random
# bytes base64. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AGENTS_TO_ENGINES_SECRET=

# Base URL apps/web uses to reach apps/agents over HTTP (SSE proxy).
AGENTS_URL=http://localhost:8080

# AES-256-GCM master key (32 random bytes, base64). Used to encrypt
# workspace AI/MCP secrets at rest. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Rotating this key requires re-encrypting all WorkspaceAiSettings and
# WorkspaceMcpServer rows.
SECRETS_ENCRYPTION_KEY=

# ── S3 / MinIO (file storage) ───────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=admin
S3_SECRET_KEY=password
S3_BUCKET=storage
S3_FORCE_PATH_STYLE=true

# ── Realtime collaboration (apps/yjs) ───────────────────────────────
NEXT_PUBLIC_YJS_URL=ws://localhost:1234
YJS_PORT=1234

# ── Agents service (apps/agents, Pillar B1) ─────────────────────────
AGENTS_SERVICE_URL=http://localhost:8080
AGENTS_SERVICE_TOKEN=test-token-123
AGENTS_LOG_LEVEL=INFO

# ── Qdrant (agents service) ─────────────────────────────────────────
QDRANT__HOST=http://localhost:6333
QDRANT__AUTH__TYPE=bearer_token
QDRANT__AUTH__BEARER_TOKEN=

OPENAI_API_KEY=

# ── Engines service (NestJS) ────────────────────────────────────────
ENGINES_PORT=8082
ENGINES_SERVICE_URL=http://localhost:8082
ENGINES_MCP_TOKEN=dev-engines-token-change-me
ENGINES_MCP_URL=http://localhost:8082/api/mcp
INDEXER_CRON_EXPRESSION=0 */5 * * * *
INDEXER_MAX_ATTEMPTS=5
INDEXER_BATCH=10
UPLOAD_INLINE_MAX_BYTES=1048576

# ── YooKassa (billing) ──────────────────────────────────────────────
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL_BASE=
YOOKASSA_TRUSTED_IPS=
# Set to "false" if your YooKassa shop does not yet have autopayments
# (Сохранение метода / Автоплатежи) approved — otherwise YooKassa returns 403 forbidden.
YOOKASSA_SAVE_PAYMENT_METHOD=true
BILLING_RENEWAL_CRON_EXPRESSION=0 0 0 * * *
BILLING_RENEWAL_BATCH_SIZE=50

# ── SendSay
SENDSAY_API_URL=https://api.sendsay.ru
SENDSAY_API_KEY=

# ── Google OAuth (better-auth socialProviders.google) ─────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── reCAPTCHA v3 (better-auth captcha plugin + apps/web frontend) ────
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# --- Server-side export (PDF) ---
# Gotenberg HTTP API URL. Must be a private endpoint in production —
# Gotenberg has no built-in auth.
GOTENBERG_URL=http://localhost:3001
# Per-request timeout (ms). Must be ≤ Gotenberg `--api-timeout`.
GOTENBERG_TIMEOUT_MS=30000

# --- PlantUML diagram rendering ---
# plantuml-server (jetty) HTTP API. Must be a private endpoint — it has no
# built-in auth; the web app proxies it via /api/plantuml/render.
PLANTUML_URL=http://localhost:3002
# Per-request timeout (ms).
PLANTUML_TIMEOUT_MS=15000

# ── Web Push (VAPID) ────────────────────────────────────────────────
# Generate locally: npx web-push generate-vapid-keys --json
# The public key must be mirrored into NEXT_PUBLIC_VAPID_PUBLIC_KEY for
# client-side use; both values are the same string.
VAPID_PUBLIC_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@anynote.dev

# ── Notifier worker (apps/engines) ──────────────────────────────────
NOTIFIER_CRON_EXPRESSION=*/5 * * * * *
NOTIFIER_BATCH_SIZE=50
NOTIFIER_MAX_ATTEMPTS=5

# SEO
YANDEX_VERIFICATION=
GOOGLE_SITE_VERIFICATION=
SEO_NOINDEX_ALL=false
