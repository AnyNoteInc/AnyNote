{
  "name": "@repo/ui",
  "version": "0.1.0",
  "private": true,
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./theme": {
      "import": "./src/theme/index.ts",
      "types": "./src/theme/index.ts"
    },
    "./components": {
      "import": "./src/components/index.ts",
      "types": "./src/components/index.ts"
    },
    "./widgets": {
      "import": "./src/widgets/index.ts",
      "types": "./src/widgets/index.ts"
    },
    "./providers": {
      "import": "./src/providers/index.ts",
      "types": "./src/providers/index.ts"
    },
    "./*": {
      "import": "./src/*",
      "types": "./src/*"
    }
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@emotion/cache": "^11.13.1",
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@mui/icons-material": "^7.3.10",
    "@mui/material": "^7.3.10",
    "@mui/material-nextjs": "^7.3.6",
    "@mui/x-chat": "9.0.0-alpha.1",
    "@mui/x-chat-headless": "9.0.0-alpha.1",
    "@mui/x-tree-view": "^9.0.1",
    "emoji-picker-react": "^4.18.0",
    "react": "^19.2.0",
    "react-hook-form": "^7.68.0",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "eslint": "^9.39.1",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
