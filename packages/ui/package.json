{
  "name": "@repo/ui",
  "version": "0.1.0",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./theme": {
      "types": "./src/theme/index.ts",
      "import": "./src/theme/index.ts",
      "default": "./src/theme/index.ts"
    },
    "./components": {
      "types": "./src/components/index.ts",
      "import": "./src/components/index.ts",
      "default": "./src/components/index.ts"
    },
    "./widgets": {
      "types": "./src/widgets/index.ts",
      "import": "./src/widgets/index.ts",
      "default": "./src/widgets/index.ts"
    },
    "./providers": {
      "types": "./src/providers/index.ts",
      "import": "./src/providers/index.ts",
      "default": "./src/providers/index.ts"
    },
    "./lib/*": {
      "types": "./src/lib/*.ts",
      "import": "./src/lib/*.ts",
      "default": "./src/lib/*.ts"
    },
    "./*": {
      "types": "./src/*",
      "import": "./src/*",
      "default": "./src/*"
    }
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@emotion/cache": "^11.13.1",
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@mui/icons-material": "^7.3.10",
    "@mui/lab": "7.0.1-beta.25",
    "@mui/material": "^7.3.11",
    "@mui/material-nextjs": "^7.3.6",
    "@mui/x-chat": "9.0.0-alpha.12",
    "@mui/x-chat-headless": "9.0.0-alpha.12",
    "@mui/x-date-pickers": "^9.8.0",
    "@mui/x-tree-view": "^9.8.0",
    "date-fns": "^4.4.0",
    "emoji-picker-react": "^4.19.1",
    "react": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
