{
  "name": "@repo/trpc",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./helpers/*": {
      "types": "./src/helpers/*.ts",
      "import": "./src/helpers/*.ts",
      "default": "./src/helpers/*.ts"
    },
    "./*": {
      "types": "./src/*",
      "import": "./src/*",
      "default": "./src/*"
    }
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hocuspocus/transformer": "^3.4.4",
    "@repo/auth": "workspace:*",
    "@repo/db": "workspace:*",
    "@repo/domain": "workspace:*",
    "@repo/mail": "workspace:*",
    "@repo/notifications": "workspace:*",
    "@repo/storage": "workspace:*",
    "@repo/telegram": "workspace:*",
    "@repo/webhooks": "workspace:*",
    "@repo/yookassa": "workspace:*",
    "@sentry/nextjs": "^10.64.0",
    "@tiptap/core": "^3.27.3",
    "@tiptap/extension-code": "^3.27.3",
    "@tiptap/extension-document": "^3.27.3",
    "@tiptap/extension-paragraph": "^3.27.3",
    "@tiptap/extension-task-item": "^3.27.3",
    "@tiptap/extension-task-list": "^3.27.3",
    "@tiptap/extension-text": "^3.27.3",
    "@tiptap/pm": "^3.27.3",
    "@tiptap/starter-kit": "^3.27.3",
    "@trpc/server": "^11.18.0",
    "date-fns": "^4.4.0",
    "jose": "^6.2.3",
    "y-prosemirror": "^1.3.7",
    "yjs": "^13.6.31",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^26.1.1",
    "eslint": "^9.39.4",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
