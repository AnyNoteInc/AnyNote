{
  "name": "@repo/editor",
  "version": "0.1.0",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./styles": {
      "import": "./src/styles/content.css",
      "default": "./src/styles/content.css"
    },
    "./extensions/server": {
      "types": "./src/extensions/server.ts",
      "import": "./src/extensions/server.ts",
      "default": "./src/extensions/server.ts"
    },
    "./lib/html-to-markdown": {
      "types": "./src/lib/html-to-markdown.ts",
      "import": "./src/lib/html-to-markdown.ts",
      "default": "./src/lib/html-to-markdown.ts"
    },
    "./*": {
      "types": "./src/*",
      "import": "./src/*",
      "default": "./src/*"
    }
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hocuspocus/provider": "^4.3.0",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@repo/diagram-board": "workspace:*",
    "@repo/mermaid": "workspace:*",
    "@repo/plantuml": "workspace:*",
    "@repo/ui": "workspace:*",
    "@tiptap-codeless/extension-file-upload": "^0.1.1",
    "@tiptap/core": "^3.27.3",
    "@tiptap/extension-code": "3.27.3",
    "@tiptap/extension-code-block-lowlight": "^3.27.3",
    "@tiptap/extension-collaboration": "^3.27.3",
    "@tiptap/extension-collaboration-caret": "^3.27.3",
    "@tiptap/extension-details": "3.27.3",
    "@tiptap/extension-drag-handle": "^3.27.3",
    "@tiptap/extension-drag-handle-react": "^3.27.3",
    "@tiptap/extension-highlight": "3.27.3",
    "@tiptap/extension-image": "^3.27.3",
    "@tiptap/extension-link": "^3.27.3",
    "@tiptap/extension-mention": "3.27.3",
    "@tiptap/extension-placeholder": "^3.27.3",
    "@tiptap/extension-table": "^3.27.3",
    "@tiptap/extension-table-cell": "^3.27.3",
    "@tiptap/extension-table-header": "^3.27.3",
    "@tiptap/extension-table-row": "^3.27.3",
    "@tiptap/extension-task-item": "^3.27.3",
    "@tiptap/extension-task-list": "^3.27.3",
    "@tiptap/extension-text": "^3.27.3",
    "@tiptap/extension-text-style": "3.27.3",
    "@tiptap/extension-typography": "^3.27.3",
    "@tiptap/extension-underline": "3.27.3",
    "@tiptap/pm": "^3.27.3",
    "@tiptap/react": "^3.27.3",
    "@tiptap/starter-kit": "^3.27.3",
    "@tiptap/suggestion": "^3.27.3",
    "@tiptap/y-tiptap": "3.0.6",
    "emoji-picker-react": "^4.19.1",
    "lowlight": "^3.3.0",
    "marked": "^14.1.3",
    "react": "^19.2.7",
    "react-drawio": "^1.0.7",
    "tippy.js": "^6.3.7",
    "turndown": "^7.2.4",
    "y-prosemirror": "^1.3.7",
    "yjs": "^13.6.31"
  },
  "peerDependencies": {
    "next": "^16.0.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "eslint": "^9.39.4",
    "next": "^16.2.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
