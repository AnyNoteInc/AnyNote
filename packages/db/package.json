{
  "name": "@repo/db",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*",
      "import": "./src/*",
      "default": "./src/*"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:db-push": "prisma db push",
    "prisma:apply-sql": "prisma db execute --file",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@hocuspocus/transformer": "^3.4.4",
    "@repo/typescript-config": "workspace:*",
    "@tiptap/extension-code": "^3.27.3",
    "@tiptap/extension-document": "^3.27.3",
    "@tiptap/extension-heading": "^3.27.3",
    "@tiptap/extension-list": "^3.27.3",
    "@tiptap/extension-paragraph": "^3.27.3",
    "@tiptap/extension-task-item": "^3.27.3",
    "@tiptap/extension-task-list": "^3.27.3",
    "@tiptap/extension-text": "^3.27.3",
    "@types/node": "^26.1.1",
    "prisma": "^7.8.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4",
    "yjs": "^13.6.31"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
