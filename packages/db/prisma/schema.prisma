// ---------------------------------------------------------------------------
// Generic databases (Phase 3). A DATABASE page owns one DatabaseSource; the
// source is a collection of item Pages bridged by DatabaseRow. The Title/Name
// column is the item Page.title (a system property, NOT a DatabaseProperty).
// Kanban (Task) models are intentionally NOT reused here.
// ---------------------------------------------------------------------------

model DatabaseSource {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId     String   @map("workspace_id") @db.Uuid
  pageId          String   @unique @map("page_id") @db.Uuid
  title           String?  @db.Text
  // Phase 4C: when locked, only OWNER/ADMIN may change structure (properties,
  // views, filters, sorts, layout); content editing stays allowed.
  structureLocked Boolean  @default(false) @map("structure_locked")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace        Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  page             Page                     @relation("DatabaseSourcePage", fields: [pageId], references: [id], onDelete: Cascade)
  views            DatabaseView[]
  properties       DatabaseProperty[]
  rows             DatabaseRow[]
  accessRules      DatabasePageAccessRule[]
  dashboardWidgets DashboardWidget[]        @relation("WidgetSource")

  @@index([workspaceId])
  @@map("database_sources")
}

// Phase 4C: page-level (row-level) database access rules. When a source has any
// enabled rule, a non-broad-access viewer sees a row only if their userId is in
// the rule's PERSON/CREATED_BY property cell (broadest-access-wins). Property
// visibility stays a cosmetic per-view setting — this is the real ACL surface.
enum DatabaseAccessLevel {
  CAN_VIEW
  CAN_COMMENT
  CAN_EDIT_CONTENT
  CAN_EDIT
  FULL_ACCESS
}

model DatabasePageAccessRule {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceId    String              @map("source_id") @db.Uuid
  propertyId  String              @map("property_id") @db.Uuid
  accessLevel DatabaseAccessLevel @map("access_level")
  enabled     Boolean             @default(true)
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  source   DatabaseSource   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  property DatabaseProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@map("database_page_access_rules")
}

model DatabaseView {
  id       String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceId String           @map("source_id") @db.Uuid
  type     DatabaseViewType @default(TABLE)
  title    String           @db.Text
  position Int              @default(0)
  settings Json?

  source           DatabaseSource    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  dashboardWidgets DashboardWidget[] @relation("WidgetView")

  @@index([sourceId])
  @@map("database_views")
}

model DatabaseProperty {
  id       String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceId String               @map("source_id") @db.Uuid
  type     DatabasePropertyType
  name     String               @db.Text
  position Int                  @default(0)
  settings Json?

  source        DatabaseSource           @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  cells         DatabaseCellValue[]
  relationLinks DatabaseRelationLink[]
  accessRules   DatabasePageAccessRule[]
  dateReminders DatabaseDateReminder[]

  @@index([sourceId])
  @@map("database_properties")
}

model DatabaseRow {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceId    String    @map("source_id") @db.Uuid
  pageId      String    @unique @map("page_id") @db.Uuid
  position    Int       @default(0)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdById String?   @map("created_by_id") @db.Uuid
  updatedById String?   @map("updated_by_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  source          DatabaseSource         @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  page            Page                   @relation("DatabaseRowPage", fields: [pageId], references: [id], onDelete: Cascade)
  cells           DatabaseCellValue[]
  relationLinks   DatabaseRelationLink[] @relation("RelationLinkSource")
  relationLinksTo DatabaseRelationLink[] @relation("RelationLinkTarget")
  dateReminders   DatabaseDateReminder[]

  @@index([sourceId, position])
  @@index([pageId])
  @@map("database_rows")
}

model DatabaseRelationLink {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  propertyId  String   @map("property_id") @db.Uuid
  rowId       String   @map("row_id") @db.Uuid
  targetRowId String   @map("target_row_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  property  DatabaseProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  row       DatabaseRow      @relation("RelationLinkSource", fields: [rowId], references: [id], onDelete: Cascade)
  targetRow DatabaseRow      @relation("RelationLinkTarget", fields: [targetRowId], references: [id], onDelete: Cascade)

  @@unique([propertyId, rowId, targetRowId])
  @@index([propertyId, rowId])
  @@index([targetRowId])
  @@map("database_relation_links")
}

