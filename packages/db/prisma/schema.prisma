generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String  @id @default(uuid(7)) @db.Uuid()
  name          String  @db.VarChar(255)
  lastName      String  @db.VarChar(255)
  firstName     String  @db.VarChar(255)
  email         String  @unique @db.VarChar(255)
  emailVerified Boolean @default(false) @map("email_verified")
  image         String? @db.VarChar(1024)

  tz                         String                       @default("UTC") @db.VarChar(50)
  createdAt                  DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime                     @updatedAt @map("updated_at") @db.Timestamptz(6)
  accounts                   Account[]
  sessions                   Session[]
  createdWorkspaces          Workspace[]                  @relation("WorkspaceCreatedBy")
  workspaceMemberships       WorkspaceMember[]
  createdPages               Page[]                       @relation("PageCreatedBy")
  updatedPages               Page[]                       @relation("PageUpdatedBy")
  pageSharesCreated          PageShare[]                  @relation("PageShareCreatedBy")
  pageShareGrants            PageShareUser[]              @relation("PageShareGrant")
  pageCommentThreadsAuthored PageCommentThread[]          @relation("PageCommentThreadAuthor")
  pageCommentsAuthored       PageComment[]                @relation("PageCommentAuthor")
  preferences                UserPreference?
  userIntegrations           Integration[]                @relation("UserIntegrations")
  subscriptions              Subscription[]
  orders                     Order[]
  chats                      Chat[]                       @relation("ChatCreator")
  favoritePages              FavoritePage[]
  favoriteChats              FavoriteChat[]
  files                      File[]
  searchHistory              SearchHistory[]
  consents                   UserConsent[]
  notifications              NotificationInApp[]          @relation("NotificationInAppOwner")
  notificationEvents         NotificationEvent[]          @relation("NotificationRecipient")
  notificationDeliveries     NotificationDelivery[]       @relation("NotificationDeliveryOwner")
  notificationPreferences    NotificationPreference[]     @relation("NotificationPreferenceOwner")
  pushSubscriptions          PushSubscription[]           @relation("PushSubscriptionOwner")
  remindersAuthored          Reminder[]                   @relation("ReminderAuthor")
  remindersCompleted         Reminder[]                   @relation("ReminderDoneBy")
  reminderRecipients         ReminderRecipient[]          @relation("ReminderRecipient")
  tasksCreated               Task[]                       @relation("TaskCreator")
  tasksUpdated               Task[]                       @relation("TaskUpdater")
  workspaceParticipants      WorkspaceParticipant[]
  taskComments               TaskComment[]
  taskActivity               TaskActivity[]
  taskAttachments            TaskAttachment[]
  mcpServersCreated          WorkspaceMcpServer[]         @relation("WorkspaceMcpServerCreatedBy")
  agentMemories              WorkspaceAgentMemory[]       @relation("WorkspaceAgentMemoryUser")
  agentActionLogs            AgentActionLog[]             @relation("AgentActionLogUser")
  apiKeys                    ApiKey[]
  aiProvidersCreated         AiProvider[]                 @relation("AiProviderCreatedBy")
  collectionsOwned           Collection[]                 @relation("CollectionOwner")
  pagesArchived              Page[]                       @relation("PageArchivedBy")
  pageRevisions              PageRevision[]               @relation("PageRevisionActor")
  pageNotificationPrefs      PageNotificationPreference[]
  databaseDateReminders      DatabaseDateReminder[]
  exportJobs                 ExportJob[]                  @relation("ExportJobUser")
  importJobs                 ImportJob[]                  @relation("ImportJobUser")
  webhookSubscriptions       WebhookSubscription[]        @relation("WebhookSubscriptionCreatedBy")
  telegramUserLink           TelegramUserLink?
  telegramLinkCodes          TelegramLinkCode[]
  workspaceBlocks            WorkspaceBlockedUser[]
  ssoProviders               SsoProvider[]                @relation("SsoProviderRegisteredBy")
  externalIdentityLinks      ExternalIdentityLink[]
  meetingArtifacts           MeetingArtifact[]            @relation("MeetingCreator")

  @@map("users")
}

model Account {
  id                    String    @id @default(uuid(7)) @db.Uuid()
  userId                String    @map("user_id") @db.Uuid()
  providerId            String    @map("provider_id") @db.VarChar(255)
  accountId             String    @map("provider_account_id") @db.VarChar(255)
  accessToken           String?   @map("access_token") @db.Text()
  refreshToken          String?   @map("refresh_token") @db.Text()
  idToken               String?   @map("id_token") @db.Text()
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at") @db.Timestamptz(6)
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at") @db.Timestamptz(6)
  scope                 String?   @db.VarChar(255)
  password              String?   @map("password") @db.VarChar(256)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id String @id @default(uuid(7)) @db.Uuid()

  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.VarChar(1024)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  userId String @map("user_id") @db.Uuid()
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model ApiKey {
  id     String @id @default(uuid(7)) @db.Uuid()
  userId String @map("user_id") @db.Uuid()

  name        String @db.VarChar(100)
  keyHash     String @unique @map("key_hash") @db.VarChar(64)
  keyPrefix   String @map("key_prefix") @db.VarChar(8)
  keyLastFour String @map("key_last_four") @db.VarChar(4)

  expiresAt  DateTime? @map("expires_at") @db.Timestamptz(6)
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("api_keys")
}

model Verification {
  id         String   @id @default(uuid(7)) @db.Uuid()
  identifier String   @db.VarChar(255)
  value      String   @unique @map("token") @db.VarChar(255)
  expiresAt  DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([identifier])
  @@map("verification_tokens")
}

/// Storage model for the `@better-auth/sso` plugin (model name `ssoProvider`).
/// Rows are managed exclusively server-side (the plugin's public /sso/register
/// endpoint is disabled via `providersLimit: 0`); the workspace-scoped source
/// of truth incl. the AES-encrypted client secret is `WorkspaceAuthProvider`
/// (Phase 8B Task 2). NOTE: `oidcConfig` is a JSON string that contains the
/// clientSecret in PLAINTEXT — the plugin reads it directly at sign-in; see
/// packages/auth/src/sso.md "Secrets".
model SsoProvider {
  id             String   @id @default(uuid(7)) @db.Uuid()
  issuer         String   @db.VarChar(500)
  domain         String   @db.VarChar(255)
  oidcConfig     String?  @map("oidc_config") @db.Text()
  samlConfig     String?  @map("saml_config") @db.Text()
  userId         String   @map("user_id") @db.Uuid()
  providerId     String   @unique @map("provider_id") @db.VarChar(64)
  organizationId String?  @map("organization_id") @db.VarChar(255)
  domainVerified Boolean  @default(false) @map("domain_verified")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user           User     @relation("SsoProviderRegisteredBy", fields: [userId], references: [id], onDelete: Cascade)

  @@index([domain])
  @@map("sso_providers")
}

model Jwks {
  id         String    @id @default(uuid(7)) @db.Uuid()
  publicKey  String    @map("public_key") @db.Text()
  privateKey String    @map("private_key") @db.Text()
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt  DateTime? @map("expires_at") @db.Timestamptz(6)

  @@map("jwks")
}

/// Immutable append-only audit log. Each consent action (sign-up, onboarding, marketing toggle) inserts a new row; no updates. Current state per (userId, documentType) = the row with the latest createdAt.
model UserConsent {
  id              String              @id @default(uuid(7)) @db.Uuid()
  userId          String              @map("user_id") @db.Uuid()
  documentType    ConsentDocumentType @map("document_type")
  granted         Boolean
  documentVersion String              @map("document_version") @db.VarChar(80)
  source          ConsentSource
  ipAddress       String?             @map("ip_address") @db.VarChar(45)
  userAgent       String?             @map("user_agent") @db.VarChar(1024)
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, documentType, createdAt(sort: Desc)])
  @@map("user_consents")
}

enum ConsentDocumentType {
  USER_AGREEMENT
  PRIVACY_POLICY
  PII_PROCESSING
  MARKETING
  PUBLIC_OFFER
}

enum ConsentSource {
  SIGN_UP
  ONBOARDING
  SETTINGS
}

enum RoleType {
  OWNER
  ADMIN
  EDITOR
  COMMENTER
  VIEWER
  GUEST
}

enum IntegrationScope {
  USER
  WORKSPACE
  BOTH
}

enum IntegrationStatus {
  PENDING
  CONNECTED
  DISCONNECTED
  ERROR
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  CANCELED
  EXPIRED
  PAST_DUE
}

enum PageType {
  TEXT
  EXCALIDRAW
  GENOGRAM
  MERMAID
  PLANTUML
  LIKEC4
  DRAWIO
  DATABASE
  KANBAN
  FORM
  MEETING
  DASHBOARD
}

enum PageShareAccess {
  RESTRICTED
  PUBLIC
}

enum PageShareRole {
  READER
  COMMENTER
  EDITOR
}

enum PageShareMode {
  LINK
  SITE
}

enum KanbanColumnKind {
  ACTIVE
  DONE
  CANCELLED
}

enum SprintStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

// Generic databases. TABLE (Phase 3); BOARD/CALENDAR/LIST (Phase 4A).
// TIMELINE/GALLERY/CHART/FEED/MAP/FORM remain roadmap-only (not added until built).
enum DatabaseViewType {
  TABLE
  BOARD
  CALENDAR
  LIST
}

enum DatabasePropertyType {
  TEXT
  NUMBER
  STATUS
  SELECT
  MULTI_SELECT
  CHECKBOX
  DATE
  PERSON
  FILE
  // Phase 4B: rich properties.
  URL
  EMAIL
  PHONE
  FORMULA // computed on read from other cells
  RELATION // links rows across database sources (DatabaseRelationLink)
  ROLLUP // computed on read: aggregate over a RELATION's target rows
  PAGE_LINK // AnyNote extension: link to an AnyNote page (not a db row)
  CREATED_TIME // readonly, derived from the item Page.createdAt
  CREATED_BY // readonly, derived from Page.createdById
  LAST_EDITED_TIME // readonly, derived from Page.updatedAt
  LAST_EDITED_BY // readonly, derived from Page.updatedById
}

enum TaskActivityType {
  CREATED
  MOVED
  STATUS_CHANGED
  PRIORITY_CHANGED
  TYPE_CHANGED
  ASSIGNED
  UNASSIGNED
  LABELED
  UNLABELED
  RENAMED
  DESCRIPTION_CHANGED
  DUE_DATE_CHANGED
  START_DATE_CHANGED
  ACTUAL_DATE_CHANGED
  SPRINT_CHANGED
  PARENT_CHANGED
  ARCHIVED
  UNARCHIVED
  ATTACHMENT_ADDED
  ATTACHMENT_REMOVED
  COMMENTED
}

enum ChatMessageRole {
  USER
  ASSISTANT
}

enum ChatMessageStatus {
  STREAMING
  DONE
  ERROR
}

// Discriminates ordinary chats from the hidden ephemeral chats backing the
// in-editor inline AI (Phase 9D). INLINE_AI chats are one-per-(user, page),
// excluded from the chat list/sidebar, and pruned on page hard-delete.
enum ChatKind {
  NORMAL
  INLINE_AI
}

enum PageOwnership {
  TEXT
  SKILL
  AGENT
}

enum PageTemplateScope {
  GLOBAL
  WORKSPACE
}

enum CollectionKind {
  TEAM
  PERSONAL
  SITE
}

enum McpTransport {
  HTTP_JSONRPC
  SSE
  STREAMABLE_HTTP
}

enum AiProviderKind {
  OLLAMA
  OPENAI
  GIGACHAT
  YANDEXGPT
  ANTHROPIC
  DEEPSEEK
}

enum ThinkingEffort {
  LOW
  MEDIUM
  HIGH
}

enum AgentMemoryScope {
  WORKSPACE
  USER
}

enum AgentMemorySource {
  USER
  AGENT
}

enum AgentActionStatus {
  OK
  ERROR
  DENIED
}

model Workspace {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(255)
  slug        String?  @unique @db.VarChar(255)
  icon        String?  @db.VarChar(64)
  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdBy             User?                    @relation("WorkspaceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  members               WorkspaceMember[]
  participants          WorkspaceParticipant[]
  pages                 Page[]
  workspaceIntegrations Integration[]            @relation("WorkspaceIntegrations")
  defaultForUsers       UserPreference[]         @relation("DefaultWorkspace")
  activeForUsers        UserPreference[]         @relation("ActiveWorkspace")
  chats                 Chat[]
  files                 File[]
  aiSettings            WorkspaceAiSettings?
  searchHistory         SearchHistory[]
  notificationEvents    NotificationEvent[]      @relation("WorkspaceNotifications")
  reminders             Reminder[]
  mcpServers            WorkspaceMcpServer[]
  agentMemories         WorkspaceAgentMemory[]
  agentActionLogs       AgentActionLog[]
  limits                WorkspaceLimit?
  aiProviders           AiProvider[]             @relation("WorkspaceAiProviders")
  collections           Collection[]
  databaseSources       DatabaseSource[]
  exportJobs            ExportJob[]
  importJobs            ImportJob[]
  webhookSubscriptions  WebhookSubscription[]
  telegramConnection    TelegramConnection?
  invitations           WorkspaceInvitation[]
  inviteLink            WorkspaceInviteLink?
  guestInvites          PageGuestInvite[]
  securityPolicy        WorkspaceSecurityPolicy?
  guestInviteRequests   PageGuestInviteRequest[]
  blockedUsers          WorkspaceBlockedUser[]
  auditLogs             WorkspaceAuditLog[]
  allowedDomains        AllowedEmailDomain[]
  verifiedDomains       VerifiedEmailDomain[]
  authProviders         WorkspaceAuthProvider[]
  seatAddon             WorkspaceSeatAddon?
  seatEvents            SeatBillingEvent[]
  seatSnapshots         WorkspaceSeatSnapshot[]
  invoiceRequests       InvoiceRequest[]
  syncedBlocks          SyncedBlock[]
  meetingArtifacts      MeetingArtifact[]
  summaryInstructions   SummaryInstruction[]
  dashboards            Dashboard[]

  @@index([createdById])
  @@map("workspaces")
}

model WorkspaceMember {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  role        RoleType
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
  @@index([userId, role])
  @@map("workspace_members")
}

model Page {
  id                String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId       String                   @map("workspace_id") @db.Uuid
  parentId          String?                  @map("parent_id") @db.Uuid
  collectionId      String?                  @map("collection_id") @db.Uuid
  type              PageType                 @default(TEXT)
  ownership         PageOwnership            @default(TEXT)
  title             String?                  @db.Text
  icon              String?                  @db.Text
  // Page appearance (Phase 9A). coverUrl: '/api/files/<id>' or an https URL;
  // coverPreset: a key from COVER_PRESET_KEYS (@repo/domain pages dto) —
  // mutually exclusive with coverUrl (service-enforced: setting one clears the other).
  coverUrl          String?                  @map("cover_url") @db.VarChar(1024)
  coverPreset       String?                  @map("cover_preset") @db.VarChar(32)
  content           Json?
  contentYjs        Bytes?                   @map("content_yjs")
  searchVector      Unsupported("tsvector")? @default(dbgenerated()) @map("search_vector")
  isTemplate        PageTemplateScope?       @map("is_template")
  templateKey       String?                  @unique @map("template_key") @db.Text
  templateMeta      Json?                    @map("template_meta")
  usageCount        Int                      @default(0) @map("usage_count")
  averageRating     Float                    @default(0) @map("average_rating")
  ratingCount       Int                      @default(0) @map("rating_count")
  prevPageId        String?                  @unique @map("prev_page_id") @db.Uuid
  archivedAt        DateTime?                @map("archived_at") @db.Timestamptz(6)
  archivedById      String?                  @map("archived_by_id") @db.Uuid
  // Copy-to-workspace provenance (Phase 2 public sharing). Informational ids only,
  // no FK — the source may be cross-workspace or deleted.
  copiedFromShareId String?                  @map("copied_from_share_id") @db.Text
  copiedFromPageId  String?                  @map("copied_from_page_id") @db.Uuid
  copiedAt          DateTime?                @map("copied_at") @db.Timestamptz(6)
  deletedAt         DateTime?                @map("deleted_at") @db.Timestamptz(6)
  createdById       String?                  @map("created_by_id") @db.Uuid
  updatedById       String?                  @map("updated_by_id") @db.Uuid
  createdAt         DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace            Workspace                    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy            User?                        @relation("PageCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy            User?                        @relation("PageUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  prevPage             Page?                        @relation("PageOrder", fields: [prevPageId], references: [id], onDelete: SetNull)
  nextPage             Page?                        @relation("PageOrder")
  children             Page[]                       @relation("PageTree")
  parent               Page?                        @relation("PageTree", fields: [parentId], references: [id], onDelete: SetNull)
  collection           Collection?                  @relation("CollectionPages", fields: [collectionId], references: [id], onDelete: SetNull)
  homePageOfCollection Collection?                  @relation("CollectionHome")
  archivedBy           User?                        @relation("PageArchivedBy", fields: [archivedById], references: [id], onDelete: SetNull)
  share                PageShare?
  commentThreads       PageCommentThread[]
  favorites            FavoritePage[]
  files                PageFile[]
  searchHistory        SearchHistory[]
  reminders            Reminder[]
  kanbanColumns        KanbanColumn[]
  kanbanTypes          KanbanType[]
  kanbanPriorities     KanbanPriority[]
  kanbanLabels         KanbanLabel[]
  sprints              Sprint[]
  tasks                Task[]
  templateTags         PageTemplateTag[]
  databaseSource       DatabaseSource?              @relation("DatabaseSourcePage")
  databaseRow          DatabaseRow?                 @relation("DatabaseRowPage")
  revisions            PageRevision[]
  notificationPrefs    PageNotificationPreference[]
  importMappings       ImportMapping[]              @relation("ImportMappingPage")
  guestInvites         PageGuestInvite[]
  guestInviteRequests  PageGuestInviteRequest[]
  syncedBlocks         SyncedBlock[]                @relation("SyncedBlockOriginPage")
  inlineAiChats        Chat[]                       @relation("ChatInlineAiPage")
  meeting              MeetingArtifact?             @relation("PageMeeting")
  dashboard            Dashboard?                   @relation("PageDashboard")

  @@index([workspaceId])
  @@index([parentId])
  @@index([collectionId])
  @@index([archivedAt])
  @@index([isTemplate])
  @@index([workspaceId, isTemplate])
  @@index([workspaceId, ownership])
  @@index([searchVector], type: Gin, name: "Page_searchVector_idx")
  @@map("pages")
}

// A synced block (Phase 9C): canonical content with its own `syncedBlock:{id}`
// Yjs document, embeddable across pages, edits propagating live to every
// instance. content/contentYjs mirror Page.content/Page.contentYjs exactly
// (JSON snapshot for export/preview/sanitize; bytes are authoritative).
// originPageId SetNull on page delete — orphan-tolerant (the safe rule):
// instances degrade to the «удалён» placeholder, never a synchronous remote
// deletion. Access is inherited from the origin page (see canAccessSyncedBlock).
model SyncedBlock {
  id           String    @id @default(uuid(7)) @db.Uuid
  workspaceId  String    @map("workspace_id") @db.Uuid
  originPageId String?   @map("origin_page_id") @db.Uuid
  content      Json?
  contentYjs   Bytes?    @map("content_yjs")
  createdById  String?   @map("created_by_id") @db.Uuid
  unsyncedAt   DateTime? @map("unsynced_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  originPage Page?     @relation("SyncedBlockOriginPage", fields: [originPageId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@map("synced_blocks")
}

model TemplateTag {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug      String            @unique @db.Text
  name      String            @db.Text
  icon      String            @db.Text
  position  Int               @default(0)
  templates PageTemplateTag[]

  @@map("template_tags")
}

model PageTemplateTag {
  pageId String @map("page_id") @db.Uuid
  tagId  String @map("tag_id") @db.Uuid

  page Page        @relation(fields: [pageId], references: [id], onDelete: Cascade)
  tag  TemplateTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([pageId, tagId])
  @@index([tagId])
  @@map("page_template_tags")
}

model Collection {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String         @map("workspace_id") @db.Uuid
  kind        CollectionKind
  title       String?        @db.Text
  description String?        @db.Text
  icon        String?        @db.Text
  color       String?        @db.Text
  ownerId     String?        @map("owner_id") @db.Uuid
  homePageId  String?        @unique @map("home_page_id") @db.Uuid
  position    Int            @default(0)
  archivedAt  DateTime?      @map("archived_at") @db.Timestamptz(6)
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner     User?     @relation("CollectionOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  homePage  Page?     @relation("CollectionHome", fields: [homePageId], references: [id], onDelete: SetNull)
  pages     Page[]    @relation("CollectionPages")

  telegramSubscriptions TelegramCollectionSubscription[]

  @@index([workspaceId, kind])
  @@index([ownerId])
  @@map("collections")
}

model PageShare {
  id                       String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pageId                   String          @unique @map("page_id") @db.Uuid
  shareId                  String          @unique @map("share_id") @db.VarChar(64)
  access                   PageShareAccess @default(RESTRICTED)
  linkRole                 PageShareRole   @default(READER) @map("link_role")
  mode                     PageShareMode   @default(LINK)
  expiresAt                DateTime?       @map("expires_at") @db.Timestamptz(6)
  // Public-site (Publish tab) fields — meaningful when mode = SITE.
  publishedAt              DateTime?       @map("published_at") @db.Timestamptz(6)
  unpublishedAt            DateTime?       @map("unpublished_at") @db.Timestamptz(6)
  allowIndexing            Boolean         @default(false) @map("allow_indexing")
  allowCopy                Boolean         @default(false) @map("allow_copy")
