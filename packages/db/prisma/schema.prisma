model Chat {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId    String         @map("workspace_id") @db.Uuid
  createdById    String         @map("created_by_id") @db.Uuid
  title          String         @default("Новый чат")
  parentId       String?        @map("parent_id") @db.Uuid
  aiModelId      String?        @map("ai_model_id") @db.Uuid
  useThinking    Boolean        @default(false) @map("use_thinking")
  thinkingEffort ThinkingEffort @default(MEDIUM) @map("thinking_effort")
  temperature    Float?         @map("temperature")
  topP           Float?         @map("top_p")
  kind           ChatKind       @default(NORMAL)
  // Set only on INLINE_AI chats: the page whose inline-AI invocations this
  // ephemeral chat backs. SetNull on page delete; the page hard-delete tx also
  // hard-deletes these rows (see PageRepository.hardDeletePageTx).
  inlineAiPageId String?        @map("inline_ai_page_id") @db.Uuid
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace    Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy    User           @relation("ChatCreator", fields: [createdById], references: [id], onDelete: Restrict)
  aiModel      AiModel?       @relation("ChatAiModel", fields: [aiModelId], references: [id], onDelete: SetNull)
  inlineAiPage Page?          @relation("ChatInlineAiPage", fields: [inlineAiPageId], references: [id], onDelete: SetNull)
  messages     ChatMessage[]
  parent       Chat?          @relation("ChatTree", fields: [parentId], references: [id], onDelete: Cascade)
  children     Chat[]         @relation("ChatTree")
  favorites    FavoriteChat[]

  // One INLINE_AI chat per (user, page). Postgres treats NULLs as DISTINCT, so
  // NORMAL chats (inlineAiPageId = NULL) never collide — only INLINE_AI rows,
  // which always set inlineAiPageId, participate. This makes the get-or-create
  // race-safe (P2002 convergence) without partial-index DDL.
  @@unique([createdById, inlineAiPageId], name: "chat_inline_ai_user_page")
  @@index([workspaceId, updatedAt(sort: Desc)])
  @@index([aiModelId])
  @@map("chats")
}

