    "@repo/typescript-config": "workspace:*",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.1",
    "jsdom": "^26.0.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
