{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NODE_ENV",
    "NEXT_PUBLIC_BASE_URL",
    "DATABASE_URL",
    "AGENTS_DATABASE_URL",
    "BETTER_AUTH_URL",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_JWT_AUDIENCE",
    "S3_ENDPOINT",
    "S3_REGION",
    "S3_ACCESS_KEY",
    "S3_SECRET_KEY",
    "S3_BUCKET",
    "S3_FORCE_PATH_STYLE",
    "NEXT_PUBLIC_YJS_URL",
    "YJS_PORT",
    "QDRANT_URL",
    "QDRANT_API_KEY",
    "QDRANT_COLLECTION",
    "OLLAMA_BASE_URL",
    "OLLAMA_DEFAULT_MODEL",
    "AGENTS_SERVICE_URL",
    "AGENTS_SERVICE_TOKEN",
    "AGENTS_LOG_LEVEL",
    "ENGINES_PORT",
    "ENGINES_MCP_TOKEN",
    "ENGINES_INDEX_DELAY_MS",
    "ENGINES_INDEX_BATCH",
    "ENGINES_INDEX_LOCK_TTL_MS",
    "EMBEDDINGS_PROVIDER",
    "EMBEDDINGS_MODEL",
    "EMBEDDINGS_DIM"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^build", "^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
