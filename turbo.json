{
  "$schema": "https://v2-9-6.turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NODE_ENV",
    "NEXT_PUBLIC_BASE_URL",
    "DATABASE_URL",
    "AGENTS_DATABASE_URL",
    "BETTER_AUTH_URL",
    "WEB_BASE_URL",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_JWT_AUDIENCE",
    "BETTER_AUTH_JWT_AGENTS_AUDIENCE",
    "S3_ENDPOINT",
    "S3_REGION",
    "S3_ACCESS_KEY",
    "S3_SECRET_KEY",
    "S3_BUCKET",
    "S3_FORCE_PATH_STYLE",
    "NEXT_PUBLIC_YJS_URL",
    "YJS_PORT",
    "QDRANT__HOST",
    "QDRANT__AUTH__TYPE",
    "QDRANT__AUTH__BEARER_TOKEN",
    "AGENTS_SERVICE_URL",
    "AGENTS_SERVICE_TOKEN",
    "AGENTS_LOG_LEVEL",
    "AGENTS_URL",
    "AGENTS_TO_ENGINES_SECRET",
    "AGENTS_JWT_SECRET",
    "ANYNOTE_MCP_URL",
    "ENGINES_PORT",
    "ENGINES_SERVICE_URL",
    "ENGINES_MCP_TOKEN",
    "ENGINES_MCP_URL",
    "INDEXER_CRON_EXPRESSION",
    "INDEXER_MAX_ATTEMPTS",
    "INDEXER_BATCH",
    "UPLOAD_INLINE_MAX_BYTES",
    "OPENAI_API_KEY",
    "HOSTNAME",
    "YOOKASSA_SHOP_ID",
    "YOOKASSA_SECRET_KEY",
    "YOOKASSA_RETURN_URL_BASE",
    "YOOKASSA_TRUSTED_IPS",
    "YOOKASSA_MOCK_ENABLED",
    "YOOKASSA_SAVE_PAYMENT_METHOD",
    "BILLING_RENEWAL_CRON_EXPRESSION",
    "BILLING_RENEWAL_BATCH_SIZE",
    "SENDSAY_API_URL",
    "SENDSAY_API_KEY",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "GOTENBERG_TIMEOUT_MS",
    "GOTENBERG_URL",
    "NEXT_PUBLIC_RECAPTCHA_SITE_KEY",
    "RECAPTCHA_SECRET_KEY",
    "SECRETS_ENCRYPTION_KEY",
    "VAPID_PUBLIC_KEY",
    "NEXT_PUBLIC_VAPID_PUBLIC_KEY",
    "VAPID_PRIVATE_KEY",
    "VAPID_SUBJECT",
    "NOTIFIER_CRON_EXPRESSION",
    "NOTIFIER_BATCH_SIZE",
    "NOTIFIER_MAX_ATTEMPTS",
    "PLAYWRIGHT",
    "GOOGLE_SITE_VERIFICATION",
    "YANDEX_VERIFICATION",
    "SEO_NOINDEX_ALL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", ".venv/**", "uv.lock"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "lint": {
      "dependsOn": ["^build", "^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
