{
  "$schema": "https://v2-9-6.turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NODE_ENV",
    "NEXT_PUBLIC_BASE_URL",
    "DATABASE_URL",
    "AGENTS_DATABASE_URL",
    "BETTER_AUTH_URL",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_JWT_AUDIENCE",
    "S3_ENDPOINT",
    "S3_REGION",
    "S3_ACCESS_KEY",
    "S3_SECRET_KEY",
    "S3_BUCKET",
    "S3_FORCE_PATH_STYLE",
    "NEXT_PUBLIC_YJS_URL",
    "YJS_PORT",
    "QDRANT__HOST",
    "QDRANT__PORT",
    "QDRANT__PROTOCOL",
    "QDRANT__AUTH__BEARER_TOKEN",
    "QDRANT__COLLECTION_NAME",
    "OLLAMA__HOST",
    "OLLAMA__PORT",
    "OLLAMA__PROTOCOL",
    "OLLAMA__EMBEDDING_MODEL",
    "AGENTS_SERVICE_URL",
    "AGENTS_SERVICE_TOKEN",
    "AGENTS_LOG_LEVEL",
    "ANYNOTE_MCP_URL",
    "ENGINES_PORT",
    "ENGINES_SERVICE_URL",
    "ENGINES_MCP_TOKEN",
    "ENGINES_MCP_URL",
    "INDEXER_CRON_EXPRESSION",
    "INDEXER_MAX_ATTEMPTS",
    "INDEXER_BATCH",
    "UPLOAD_INLINE_MAX_BYTES",
    "OPENAI_API_KEY",
    "HOSTNAME"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", ".venv/**", "uv.lock"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "lint": {
      "dependsOn": ["^build", "^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
